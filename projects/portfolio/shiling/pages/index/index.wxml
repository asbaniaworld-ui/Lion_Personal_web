<!--index.wxml-->
<view class="container">
  <!-- Header -->
  <view class="header">
    <view class="title-container">
      <view class="earth-icon">🌍</view>
      <view class="title-group">
        <view class="title-main">拾领星球</view>
        <view class="title-sub">Find my stuff.</view>
      </view>
    </view>
    
    <!-- 搜索栏 -->
    <view class="search-container">
      <input 
        class="search-bar" 
        placeholder="搜索失物..." 
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        confirm-type="search"
        bindconfirm="onSearch"
      />
      <button class="search-btn" bindtap="onSearch">搜索</button>
    </view>
    
    <!-- 筛选标签 -->
    <view class="filter-tabs">
      <button 
        class="filter-btn {{currentFilter === 'all' ? 'active' : ''}}" 
        data-filter="all"
        bindtap="onFilter"
      >全部</button>
      <button 
        class="filter-btn {{currentFilter === 'lost' ? 'active' : ''}}" 
        data-filter="lost"
        bindtap="onFilter"
      >失物</button>
      <button 
        class="filter-btn {{currentFilter === 'found' ? 'active' : ''}}" 
        data-filter="found"
        bindtap="onFilter"
      >招领</button>
    </view>
  </view>

  <!-- 物品列表 -->
  <scroll-view class="items-container" scroll-y>
    <view 
      wx:for="{{displayItems}}" 
      wx:key="id"
      class="item-card-link"
      data-id="{{item.id}}"
      bindtap="navigateToDetail"
    >
      <view class="item-card">
        <view class="item-image">
          <image 
            src="{{item.image}}" 
            mode="aspectFill"
            class="item-image-img"
            lazy-load
          />
        </view>
        <view class="item-info">
          <view class="item-header">
            <text class="item-title">{{item.itemName}}</text>
            <view class="type-badge {{item.itemType}}">
              <text class="type-badge-text">{{item.itemType === 'found' ? '招领' : '失物'}}</text>
            </view>
          </view>
          <text class="item-description">{{item.description}}</text>
          <view class="item-footer">
            <text class="location">📍 {{item.location}}</text>
            <text class="date">{{item.date}}</text>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 空状态 -->
    <view wx:if="{{displayItems.length === 0}}" class="empty-state">
      <text class="empty-text">暂无数据</text>
    </view>
  </scroll-view>

  <!-- 底部导航栏 -->
  <view class="bottom-nav">
    <view 
      class="nav-btn active" 
      bindtap="navigateToIndex"
    >
      <text class="nav-icon">🏠</text>
      <text class="nav-label">首页</text>
    </view>
    <view 
      class="nav-btn" 
      bindtap="navigateToPublish"
    >
      <text class="nav-icon">➕</text>
      <text class="nav-label">发布</text>
    </view>
    <view 
      class="nav-btn" 
      bindtap="navigateToProfile"
    >
      <text class="nav-icon">👤</text>
      <text class="nav-label">个人主页</text>
    </view>
  </view>
</view>

