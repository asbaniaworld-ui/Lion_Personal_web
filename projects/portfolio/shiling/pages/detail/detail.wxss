/**detail.wxss**/
page {
  background-color: var(--bg-primary, #000000);
  min-height: 100vh;
  color: var(--text-primary, #ffffff);
}

/* 详情页容器 */
.detail-container {
  max-width: 100%;
  padding: 20rpx;
  background: linear-gradient(180deg, var(--bg-primary, #000000) 0%, var(--bg-secondary, #0a0a0a) 50%, var(--bg-primary, #000000) 100%);
}

/* 返回按钮 */
.back-button {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 16rpx 24rpx;
  background: var(--bg-card, rgba(255, 255, 255, 0.1));
  color: var(--text-primary, #ffffff);
  border: 2rpx solid var(--border-color, rgba(255, 255, 255, 0.2));
  border-radius: 40rpx;
  width: fit-content;
  box-shadow: 0 4rpx 12rpx var(--shadow-color, rgba(0, 0, 0, 0.3));
  backdrop-filter: blur(10rpx);
}

.back-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
  color: var(--accent-color, #ffa500);
}

.back-text {
  font-size: 26rpx;
  font-weight: 600;
}

/* 物品图片区域 */
.item-image-section {
  background: var(--bg-card, rgba(255, 255, 255, 0.05));
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx var(--shadow-color, rgba(0, 0, 0, 0.3));
  margin-bottom: 20rpx;
  text-align: center;
  border: 2rpx solid var(--accent-glow, rgba(255, 165, 0, 0.2));
  backdrop-filter: blur(10rpx);
}

.item-image {
  width: 100%;
  max-width: 500rpx;
  max-height: 500rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.5);
  border: 2rpx solid rgba(255, 165, 0, 0.3);
}

/* 物品信息区域 */
.item-info-section {
  background: var(--bg-card, rgba(255, 255, 255, 0.05));
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx var(--shadow-color, rgba(0, 0, 0, 0.3));
  margin-bottom: 20rpx;
  border: 2rpx solid var(--border-color, rgba(255, 255, 255, 0.1));
  backdrop-filter: blur(10rpx);
}

/* 物品名称标题 */
.item-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary, #ffffff);
  margin-bottom: 16rpx;
  line-height: 1.3;
  display: block;
  text-shadow: 0 0 20rpx var(--accent-glow, rgba(255, 255, 255, 0.1));
}

/* 物品类型和日期 */
.item-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
  flex-wrap: wrap;
}

.type-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 24rpx;
  border-radius: 32rpx;
  font-weight: 600;
  text-transform: uppercase;
  line-height: 1.2;
  min-height: 40rpx;
  height: fit-content;
  white-space: nowrap;
  flex-shrink: 0;
}

.type-badge-text {
  font-size: 22rpx;
  line-height: 1;
}

.type-badge.found {
  background: rgba(255, 165, 0, 0.2);
  color: #ffa500;
  border: 2rpx solid rgba(255, 165, 0, 0.3);
}

.type-badge.lost {
  background: rgba(255, 100, 100, 0.2);
  color: #ff6464;
  border: 2rpx solid rgba(255, 100, 100, 0.3);
}

.item-date {
  color: var(--text-tertiary, rgba(255, 255, 255, 0.7));
  font-size: 24rpx;
}

/* 详情信息块 */
.info-block {
  margin-bottom: 24rpx;
}

.info-label {
  font-size: 22rpx;
  color: var(--text-tertiary, rgba(255, 255, 255, 0.6));
  text-transform: uppercase;
  letter-spacing: 1rpx;
  margin-bottom: 8rpx;
  font-weight: 600;
  display: block;
}

.info-content {
  font-size: 28rpx;
  color: var(--text-primary, #ffffff);
  line-height: 1.6;
  display: block;
}

/* 详细描述 */
.item-description {
  background: var(--bg-card, rgba(255, 255, 255, 0.05));
  padding: 20rpx;
  border-radius: 16rpx;
  border-left: 6rpx solid var(--accent-color, #ffa500);
  margin-top: 8rpx;
}

.description-text {
  font-size: 26rpx;
  color: var(--text-secondary, rgba(255, 255, 255, 0.8));
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-all;
}

/* 联系方式区域 */
.contact-section {
  background: var(--bg-card, rgba(255, 255, 255, 0.05));
  padding: 20rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid var(--accent-glow, rgba(255, 165, 0, 0.2));
}

.contact-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-top: 8rpx;
}

.contact-label {
  font-size: 24rpx;
  color: var(--text-tertiary, rgba(255, 255, 255, 0.6));
  font-weight: 600;
}

.contact-value {
  font-size: 28rpx;
  color: var(--accent-color, #ffa500);
  font-weight: 500;
}

/* 按钮区域 */
.action-buttons {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
  flex-wrap: wrap;
}

.btn {
  flex: 1;
  min-width: 240rpx;
  padding: 20rpx 32rpx;
  border: none;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: var(--accent-color, #ffa500);
  color: var(--btn-text-color, #000000);
  position: relative;
  overflow: visible;
  box-shadow: 
    0 0 10rpx rgba(255, 165, 0, 0.5),
    0 0 20rpx rgba(255, 165, 0, 0.3),
    0 0 30rpx rgba(255, 165, 0, 0.2),
    0 8rpx 30rpx rgba(255, 165, 0, 0.4);
  font-weight: 600;
  animation: particleGlow 3s ease-in-out infinite;
}

.btn-primary::before {
  content: '';
  position: absolute;
  top: -2rpx;
  left: -2rpx;
  right: -2rpx;
  bottom: -2rpx;
  border-radius: 20rpx;
  background: linear-gradient(45deg, 
    transparent 30%, 
    rgba(255, 165, 0, 0.8) 50%, 
    transparent 70%);
  background-size: 200% 200%;
  animation: particleFlow 4s linear infinite;
  z-index: -1;
  opacity: 0.6;
}

.btn-primary::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 100%;
  height: 100%;
  transform: translate(-50%, -50%);
  border-radius: 20rpx;
  background: radial-gradient(circle at var(--x, 50%) var(--y, 50%), 
    rgba(255, 165, 0, 0.4) 0%, 
    rgba(255, 165, 0, 0.2) 30%, 
    transparent 70%);
  animation: particleMove 5s ease-in-out infinite;
  z-index: -1;
  pointer-events: none;
}

.btn-primary:active {
  background: #ff8c00;
  box-shadow: 
    0 0 8rpx rgba(255, 165, 0, 0.4),
    0 0 15rpx rgba(255, 165, 0, 0.3),
    0 4rpx 15rpx rgba(255, 165, 0, 0.3);
}

.btn-secondary {
  background: var(--bg-card, rgba(255, 255, 255, 0.1));
  color: var(--text-primary, #ffffff);
  border: 2rpx solid var(--border-color, rgba(255, 255, 255, 0.3));
  backdrop-filter: blur(10rpx);
  position: relative;
  overflow: visible;
  box-shadow: 
    0 0 8rpx var(--shadow-color, rgba(255, 255, 255, 0.1)),
    0 0 15rpx var(--shadow-color, rgba(255, 255, 255, 0.05));
  transition: all 0.3s ease;
}

.btn-secondary::before {
  content: '';
  position: absolute;
  top: -2rpx;
  left: -2rpx;
  right: -2rpx;
  bottom: -2rpx;
  border-radius: 20rpx;
  background: linear-gradient(45deg, 
    transparent 30%, 
    rgba(255, 255, 255, 0.3) 50%, 
    transparent 70%);
  background-size: 200% 200%;
  animation: particleFlow 5s linear infinite;
  z-index: -1;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.btn-secondary:active::before {
  opacity: 0.4;
}

.btn-secondary:active {
  background: rgba(255, 255, 255, 0.15);
  box-shadow: 
    0 0 12rpx rgba(255, 255, 255, 0.2),
    0 0 20rpx rgba(255, 255, 255, 0.1);
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes particleGlow {
  0%, 100% {
    box-shadow: 
      0 0 10rpx rgba(255, 165, 0, 0.5),
      0 0 20rpx rgba(255, 165, 0, 0.3),
      0 0 30rpx rgba(255, 165, 0, 0.2),
      0 8rpx 30rpx rgba(255, 165, 0, 0.4);
  }
  50% {
    box-shadow: 
      0 0 15rpx rgba(255, 165, 0, 0.7),
      0 0 30rpx rgba(255, 165, 0, 0.5),
      0 0 45rpx rgba(255, 165, 0, 0.3),
      0 8rpx 30rpx rgba(255, 165, 0, 0.5);
  }
}

@keyframes particleFlow {
  0% {
    background-position: 0% 50%;
  }
  100% {
    background-position: 200% 50%;
  }
}

@keyframes particleMove {
  0%, 100% {
    --x: 20%;
    --y: 30%;
    opacity: 0.3;
  }
  25% {
    --x: 80%;
    --y: 20%;
    opacity: 0.5;
  }
  50% {
    --x: 50%;
    --y: 80%;
    opacity: 0.4;
  }
  75% {
    --x: 30%;
    --y: 70%;
    opacity: 0.6;
  }
}

.item-image-section,
.item-info-section {
  animation: fadeIn 0.6s ease-out;
}

.item-info-section {
  animation-delay: 0.2s;
  animation-fill-mode: both;
}

