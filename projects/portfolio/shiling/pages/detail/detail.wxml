<!--detail.wxml-->
<view class="detail-container">
  <!-- 返回按钮 -->
  <view class="back-button" bindtap="goBack">
    <text class="back-icon">←</text>
    <text class="back-text">返回首页</text>
  </view>

  <!-- 物品图片 -->
  <view class="item-image-section">
    <image 
      src="{{item.image}}" 
      mode="aspectFit"
      class="item-image"
      lazy-load
    />
  </view>

  <!-- 物品信息 -->
  <view class="item-info-section">
    <text class="item-title">{{item.itemName}}</text>
    
    <view class="item-meta">
      <view class="type-badge {{item.itemType}}">
        <text class="type-badge-text">{{item.itemType === 'found' ? '招领' : '失物'}}</text>
      </view>
      <text class="item-date">发布时间：{{item.date}}</text>
    </view>

    <!-- 发现位置 -->
    <view class="info-block">
      <text class="info-label">发现位置</text>
      <text class="info-content">📍 {{item.location}}</text>
    </view>

    <!-- 详细描述 -->
    <view class="info-block">
      <text class="info-label">详细描述</text>
      <view class="item-description">
        <text class="description-text">{{item.description}}</text>
      </view>
    </view>

    <!-- 联系方式 -->
    <view class="contact-section">
      <text class="info-label">联系方式</text>
      <view class="contact-info">
        <text class="contact-label">联系电话：</text>
        <text class="contact-value">{{item.contact}}</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-buttons">
      <button 
        class="btn btn-primary" 
        bindtap="onContact"
        wx:if="{{hasPhone}}"
      >联系Ta</button>
      <button 
        class="btn btn-secondary" 
        bindtap="goBack"
      >返回首页</button>
    </view>
  </view>
</view>

